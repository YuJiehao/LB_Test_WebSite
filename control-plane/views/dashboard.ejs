<%#
   =========================================================================
   dashboard.ejs --  Main dashboard page for the control plane
   Renders via layout.ejs which provides the HTML shell (head/nav/footer).
   Required (from res.render):
     title        (string)  page title
     pods         (Array)   discovered pod list with {name, ip, mode, ...}
     labelSelector (string) current label selector filter
   =========================================================================
%><%
  const _title = typeof title !== 'undefined' ? title : 'LB Fault Control Plane';
  const _active = typeof active !== 'undefined' ? active : '';
  const _serverIP = typeof serverIP !== 'undefined' ? serverIP : '';
  const _pods = typeof pods !== 'undefined' ? pods : [];
  const _labelSelector = typeof labelSelector !== 'undefined' ? labelSelector : 'app=load-balancer-test';

  // ---- Build table rows (via pod-row partial) ----
  let rowsHtml = '';
  if (_pods.length === 0) {
    rowsHtml = '<tr><td colspan="5" class="pod-table__empty">No pods discovered</td></tr>';
  } else {
    for (const p of _pods) {
      rowsHtml += include('partials/pod-row', { pod: p });
    }
  }

  // ---- Hero section ----
  const heroHtml = `
    <section class="dashboard-hero">
      <div class="dashboard-hero__inner">
        <h1>LB Fault Control Plane</h1>
        <p class="dashboard-hero__sub">Kubernetes fault-injection management dashboard</p>
      </div>
    </section>
  `;

  // ---- Label filter bar ----
  const filterHtml = `
    <section class="filter-bar">
      <form class="filter-bar__form" id="label-filter" action="/" method="GET">
        <label for="label-selector" class="filter-bar__label">Label selector</label>
        <input type="text" id="label-selector" name="selector"
               class="filter-bar__input"
               value="${_labelSelector}" placeholder="app=load-balancer-test">
        <button type="submit" class="btn btn--sm">Filter</button>
      </form>
    </section>
  `;

  // ---- Pod table ----
  const tableHtml = `
    <section class="pod-table-section">
      <h2 class="section-title">Pods</h2>
      <div class="table-wrap">
        <table class="pod-table">
          <thead>
            <tr>
              <th>Pod Name</th>
              <th>IP</th>
              <th>Current Mode</th>
              <th>Status</th>
              <th></th>
            </tr>
          </thead>
          <tbody>${rowsHtml}</tbody>
        </table>
      </div>
    </section>
  `;

  // ---- Action form ----
  const modes = ['none', 'http_500', 'http_503', 'slow', 'wrong_body', 'reset'];
  const modeOptionsHtml = modes.map(function(m) {
    return '<option value="' + m + '">' + m + '</option>';
  }).join('');

  const actionFormHtml = `
    <section class="action-section">
      <h2 class="section-title">Inject Fault</h2>
      <form class="action-form" action="/api/fault/apply" method="POST">
        <fieldset class="action-form__fieldset">
          <legend class="action-form__legend">Target</legend>
          <div class="action-form__radios">
            <label class="action-form__radio">
              <input type="radio" name="target[type]" value="all" checked> All Pods
            </label>
            <label class="action-form__radio">
              <input type="radio" name="target[type]" value="single"> Single Pod
              <input type="text" name="target[pod]" class="action-form__inline-input" placeholder="pod-name" disabled>
              <span class="action-form__hint">Enter exact pod name</span>
            </label>
            <label class="action-form__radio">
              <input type="radio" name="target[type]" value="selector"> Selector
              <input type="text" name="target[selector]" class="action-form__inline-input" placeholder="app=lb-test" disabled>
              <span class="action-form__hint">Must contain <code>=</code> (e.g., <code>app=lb-test</code>)</span>
            </label>
            <label class="action-form__radio">
              <input type="radio" name="target[type]" value="canary"> Canary %
              <input type="number" name="target[percent]" class="action-form__inline-input" placeholder="25" min="0" max="100" disabled>
              <span class="action-form__hint">0–100</span>
            </label>
          </div>
        </fieldset>

        <fieldset class="action-form__fieldset">
          <legend class="action-form__legend">Mode</legend>
          <div class="action-form__mode-row">
            <select name="mode" class="action-form__select">
              ${modeOptionsHtml}
            </select>
            <label class="action-form__delay">
              Slow delay (ms)
              <input type="number" name="slowDelayMs" class="action-form__inline-input" value="3000" min="100" max="30000" step="100" title="Delay in ms before health check responds (100-30000)">
            </label>
          </div>
        </fieldset>

        <div class="action-form__actions">
          <button type="submit" class="btn btn--primary">Apply Fault</button>
        </div>
      </form>
    </section>
  `;

  const bodyHtml = heroHtml + filterHtml + actionFormHtml + tableHtml;
%><%- include('layout', {
  title: _title,
  active: _active,
  serverIP: _serverIP,
  body: bodyHtml,
  extraScript: '<script src="/js/dashboard.js"></script>',
  extraCss: '<style>.dashboard-hero{background:var(--color-bg-card);border-radius:var(--radius-card);padding:var(--space-6);margin-bottom:var(--space-4)}.dashboard-hero__inner h1{font-size:1.5rem;font-weight:700;margin:0 0 var(--space-1)}.dashboard-hero__sub{color:var(--color-text-muted);margin:0}.filter-bar{margin-bottom:var(--space-4)}.filter-bar__form{display:flex;align-items:center;gap:var(--space-2)}.filter-bar__label{font-size:0.875rem;font-weight:600;white-space:nowrap}.filter-bar__input{flex:1;max-width:360px;padding:var(--space-1) var(--space-2);border:1px solid var(--color-border, #d1d5db);border-radius:var(--radius-input);background:var(--color-bg-card);color:var(--color-text);font-family:var(--font-mono);font-size:0.875rem}.btn{display:inline-flex;align-items:center;gap:var(--space-1);padding:var(--space-1) var(--space-3);border:1px solid var(--color-primary);border-radius:var(--radius-btn);background:var(--color-primary);color:#fff;cursor:pointer;font-size:0.875rem;font-weight:500}.btn--sm{padding:var(--space-1) var(--space-2);font-size:0.8125rem}.btn--xs{padding:2px var(--space-1);font-size:0.75rem;border-color:var(--color-text-muted);background:transparent;color:var(--color-text)}.table-wrap{overflow-x:auto}.pod-table{width:100%;border-collapse:collapse;font-size:0.875rem}.pod-table th,.pod-table td{padding:var(--space-2) var(--space-3);text-align:left;border-bottom:1px solid var(--color-border,#e5e7eb)}.pod-table thead th{font-weight:600;color:var(--color-text-muted);font-size:0.75rem;text-transform:uppercase;letter-spacing:0.05em;background:var(--color-bg-muted)}.pod-table tbody tr:hover{background:var(--color-bg-muted)}.pod-table__empty{text-align:center;color:var(--color-text-muted);padding:var(--space-6)}.pod-row__name{font-weight:600;font-family:var(--font-mono)}.pod-row__ip{font-family:var(--font-mono)}.pod-row__mode code{background:var(--color-bg-muted);padding:2px var(--space-1);border-radius:4px;font-size:0.8125rem}.badge{display:inline-block;padding:2px var(--space-2);border-radius:var(--radius-pill);font-size:0.75rem;font-weight:600;text-transform:uppercase}.badge.status-ok{background:#d1fae5;color:#065f46}.badge.status-warn{background:#fef3c7;color:#92400e}.badge.status-err{background:#fee2e2;color:#991b1b}.section-title{font-size:1.125rem;font-weight:700;margin:0 0 var(--space-3)}.action-section{margin-bottom:var(--space-4)}.action-form{background:var(--color-bg-card);border:1px solid var(--color-border,#e5e7eb);border-radius:var(--radius-card);padding:var(--space-4)}.action-form__fieldset{border:1px solid var(--color-border,#e5e7eb);border-radius:var(--radius-input);padding:var(--space-3);margin-bottom:var(--space-3)}.action-form__legend{font-weight:600;font-size:0.875rem;padding:0 var(--space-1)}.action-form__radios{display:flex;flex-direction:column;gap:var(--space-2)}.action-form__radio{display:flex;align-items:center;gap:var(--space-2);font-size:0.875rem;cursor:pointer}.action-form__hint{font-size:0.75rem;color:var(--color-text-muted);white-space:nowrap}.action-form__hint code{font-size:0.6875rem;background:var(--color-bg-muted);padding:1px 3px;border-radius:3px}.action-form__inline-input{padding:var(--space-1) var(--space-2);border:1px solid var(--color-border,#d1d5db);border-radius:var(--radius-input);background:var(--color-bg);color:var(--color-text);font-size:0.8125rem;font-family:var(--font-mono);width:140px}.action-form__inline-input:disabled{opacity:0.5;cursor:not-allowed}.action-form__mode-row{display:flex;align-items:center;gap:var(--space-3)}.action-form__select{padding:var(--space-1) var(--space-2);border:1px solid var(--color-border,#d1d5db);border-radius:var(--radius-input);background:var(--color-bg-card);color:var(--color-text);font-size:0.875rem}.action-form__delay{display:flex;align-items:center;gap:var(--space-1);font-size:0.8125rem;color:var(--color-text-muted)}.action-form__actions{display:flex;justify-content:flex-end}.btn--primary{background:var(--color-primary);color:#fff;border-color:var(--color-primary)}</style>',
}) %>
