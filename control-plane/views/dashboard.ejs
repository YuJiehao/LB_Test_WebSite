<%#
   =========================================================================
   dashboard.ejs --  Main dashboard page for the control plane
   Renders via layout.ejs which provides the HTML shell (head/nav/footer).
   Required (from res.render):
     title        (string)  page title
     pods         (Array)   discovered pod list with {name, ip, mode, ...}
     labelSelector (string) current label selector filter
   =========================================================================
%><%
  const _title = typeof title !== 'undefined' ? title : 'LB Fault Control Plane';
  const _active = typeof active !== 'undefined' ? active : '';
  const _serverIP = typeof serverIP !== 'undefined' ? serverIP : '';
  const _pods = typeof pods !== 'undefined' ? pods : [];
  const _labelSelector = typeof labelSelector !== 'undefined' ? labelSelector : 'app=load-balancer-test';

  // ---- Build table rows (via pod-row partial) ----
  let rowsHtml = '';
  if (_pods.length === 0) {
    rowsHtml = '<tr><td colspan="6" class="pod-table__empty">No pods discovered</td></tr>';
  } else {
    for (const p of _pods) {
      rowsHtml += include('partials/pod-row', { pod: p });
    }
  }

  // ---- Header bar ----
  const podCountUp = _pods.filter(function(p) { return p.mode === 'none'; }).length;
  const podCountDown = _pods.length - podCountUp;
  const headerHtml = `
    <section class="dashboard-header">
      <div class="dashboard-header__left">
        <span class="dashboard-header__icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></span>
        <div>
          <h1 class="dashboard-header__title">Fault Injection Control</h1>
          <p class="dashboard-header__sub">${_pods.length} pods · ${podCountUp} healthy · ${podCountDown} faulted</p>
        </div>
      </div>
      <div class="dashboard-header__right">
        <span class="dashboard-header__badge" title="Label selector: ${_labelSelector}">${_labelSelector}</span>
      </div>
    </section>
  `;

  // ---- Pod table ----
  const tableHtml = `
    <section class="pod-table-section">
      <h2 class="section-title">Pods</h2>
      <div class="table-wrap">
        <table class="pod-table">
          <thead>
            <tr>
              <th>Pod Name</th>
              <th>IP</th>
              <th>Labels</th>
              <th>Current Mode</th>
              <th>Status</th>
              <th></th>
            </tr>
          </thead>
          <tbody>${rowsHtml}</tbody>
        </table>
      </div>
    </section>
  `;

  // ---- Action form ----
  const modes = ['none', 'http_500', 'http_503', 'slow', 'wrong_body', 'reset'];
  const modeOptionsHtml = modes.map(function(m) {
    return '<option value="' + m + '">' + m + '</option>';
  }).join('');

  const actionFormHtml = `
    <section class="action-section">
      <h2 class="section-title">Inject Fault</h2>
      <form class="action-form" action="/api/fault/apply" method="POST">
        <fieldset class="action-form__fieldset">
          <legend class="action-form__legend">Target</legend>
          <div class="action-form__radios">
            <label class="action-form__radio">
              <input type="radio" name="target[type]" value="all" checked> All Pods
            </label>
            <label class="action-form__radio">
              <input type="radio" name="target[type]" value="single"> Single Pod
              <select name="target[pod]" class="action-form__inline-input" data-target-type="single" disabled>
                <option value="">-- select pod --</option>
                ${_pods.map(function(p) { return '<option value="' + p.name + '">' + p.name + '</option>'; }).join('')}
              </select>
            </label>
            <label class="action-form__radio">
              <input type="radio" name="target[type]" value="selector"> Selector
              <input type="text" name="target[selector]" class="action-form__inline-input" data-target-type="selector" placeholder="app=lb-test" disabled>
              <span class="action-form__hint">Must contain <code>=</code> (e.g., <code>app=lb-test</code>)</span>
            </label>
            <label class="action-form__radio">
              <input type="radio" name="target[type]" value="canary"> Canary %
              <input type="number" name="target[percent]" class="action-form__inline-input" data-target-type="canary" placeholder="25" min="0" max="100" disabled>
              <span class="action-form__hint">0–100</span>
            </label>
          </div>
        </fieldset>

        <fieldset class="action-form__fieldset">
          <legend class="action-form__legend">Mode</legend>
          <div class="action-form__mode-row">
            <select name="mode" class="action-form__select">
              ${modeOptionsHtml}
            </select>
            <label class="action-form__delay">
              Slow delay (ms)
              <input type="number" name="slowDelayMs" class="action-form__inline-input" value="3000" min="100" max="30000" step="100" title="Delay in ms before health check responds (100-30000)">
            </label>
          </div>
        </fieldset>

        <div class="action-form__actions">
          <button type="submit" class="btn btn--primary">Apply Fault</button>
        </div>
      </form>
    </section>
  `;

  const bodyHtml = headerHtml + actionFormHtml + tableHtml;
%><%- include('layout', {
  title: _title,
  active: _active,
  serverIP: _serverIP,
  body: bodyHtml,
  extraScript: '<script src="/js/dashboard.js"></script>',
  extraCss: '<style>.dashboard-header{display:flex;align-items:center;justify-content:space-between;gap:var(--space-4);padding:var(--space-4) var(--space-5);margin-bottom:var(--space-4);background:var(--color-bg-card);border:1px solid var(--color-border,#e5e7eb);border-radius:var(--radius-card)}.dashboard-header__left{display:flex;align-items:center;gap:var(--space-3)}.dashboard-header__icon{color:var(--color-primary);flex-shrink:0}.dashboard-header__title{font-size:1.125rem;font-weight:700;margin:0;line-height:1.3}.dashboard-header__sub{font-size:0.8125rem;color:var(--color-text-muted);margin:0}.dashboard-header__right{flex-shrink:0}.dashboard-header__badge{display:inline-block;padding:3px 10px;border-radius:var(--radius-pill);font-size:0.6875rem;font-family:var(--font-mono);color:var(--color-text-muted);background:var(--color-bg-muted);border:1px solid var(--color-border,#e5e7eb)}.btn{display:inline-flex;align-items:center;gap:var(--space-1);padding:var(--space-1) var(--space-3);border:1px solid var(--color-primary);border-radius:var(--radius-btn);background:var(--color-primary);color:#fff;cursor:pointer;font-size:0.875rem;font-weight:500}.btn--sm{padding:var(--space-1) var(--space-2);font-size:0.8125rem}.btn--xs{padding:2px var(--space-1);font-size:0.75rem;border-color:var(--color-text-muted);background:transparent;color:var(--color-text)}.table-wrap{overflow-x:auto}.pod-table{width:100%;border-collapse:collapse;font-size:0.875rem}.pod-table th,.pod-table td{padding:var(--space-2) var(--space-3);text-align:left;border-bottom:1px solid var(--color-border,#e5e7eb)}.pod-table thead th{font-weight:600;color:var(--color-text-muted);font-size:0.75rem;text-transform:uppercase;letter-spacing:0.05em;background:var(--color-bg-muted)}.pod-table tbody tr:hover{background:var(--color-bg-muted)}.pod-table__empty{text-align:center;color:var(--color-text-muted);padding:var(--space-6)}.pod-row__labels{max-width:260px}.label-chip{display:inline-block;margin:1px 2px;padding:0 5px;border-radius:3px;font-size:0.6875rem;font-family:var(--font-mono);line-height:1.6;background:var(--color-bg-muted);color:var(--color-text-muted);border:1px solid var(--color-border,#d1d5db);white-space:nowrap}.pod-row__name{font-weight:600;font-family:var(--font-mono)}.pod-row__ip{font-family:var(--font-mono)}.pod-row__mode code{background:var(--color-bg-muted);padding:2px var(--space-1);border-radius:4px;font-size:0.8125rem}.badge{display:inline-block;padding:2px var(--space-2);border-radius:var(--radius-pill);font-size:0.75rem;font-weight:600;text-transform:uppercase}.badge.status-ok{background:#d1fae5;color:#065f46}.badge.status-warn{background:#fef3c7;color:#92400e}.badge.status-err{background:#fee2e2;color:#991b1b}.section-title{font-size:1.125rem;font-weight:700;margin:0 0 var(--space-3)}.action-section{margin-bottom:var(--space-4)}.action-form{background:var(--color-bg-card);border:1px solid var(--color-border,#e5e7eb);border-radius:var(--radius-card);padding:var(--space-4)}.action-form__fieldset{border:1px solid var(--color-border,#e5e7eb);border-radius:var(--radius-input);padding:var(--space-3);margin-bottom:var(--space-3)}.action-form__legend{font-weight:600;font-size:0.875rem;padding:0 var(--space-1)}.action-form__radios{display:flex;flex-direction:column;gap:var(--space-2)}.action-form__radio{display:flex;align-items:center;gap:var(--space-2);font-size:0.875rem;cursor:pointer}.action-form__hint{font-size:0.75rem;color:var(--color-text-muted);white-space:nowrap}.action-form__hint code{font-size:0.6875rem;background:var(--color-bg-muted);padding:1px 3px;border-radius:3px}.action-form__inline-input{padding:var(--space-1) var(--space-2);border:1px solid var(--color-border,#d1d5db);border-radius:var(--radius-input);background:var(--color-bg);color:var(--color-text);font-size:0.8125rem;font-family:var(--font-mono);width:auto;min-width:140px}.action-form__inline-input:disabled{opacity:0.5;cursor:not-allowed}.action-form__inline-input[data-target-type="single"]{min-width:320px}.action-form__mode-row{display:flex;align-items:center;gap:var(--space-3)}.action-form__select{padding:var(--space-1) var(--space-2);border:1px solid var(--color-border,#d1d5db);border-radius:var(--radius-input);background:var(--color-bg-card);color:var(--color-text);font-size:0.875rem}.action-form__delay{display:flex;align-items:center;gap:var(--space-1);font-size:0.8125rem;color:var(--color-text-muted)}.action-form__actions{display:flex;justify-content:flex-end}.btn--primary{background:var(--color-primary);color:#fff;border-color:var(--color-primary)}</style>',
}) %>
